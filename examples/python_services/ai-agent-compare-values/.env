# ============================================================
# AI Agent - 环境变量配置文件
# 复制此文件为 .env 并填写实际值
# ============================================================

# ==================== 基础配置 ====================

# 配置文件路径（默认: config.yaml）
CONFIG_PATH=config.yaml

# gRPC 服务端口（默认: 50054）
GRPC_PORT=50054

# ==================== MCP 服务配置 ====================

# MCP SSE 服务端口（默认: 8765）
MCP_PORT=8765

# ==================== LLM 配置 ====================

# LLM 服务地址（默认: http://localhost:11434/v1）
LLM_BASE_URL=http://localhost:11434/v1

# LLM 模型名称（默认: llama3:8b）
LLM_MODEL=llama3:8b

# LLM API 密钥（默认: ollama，使用 ollama 时可为占位符）
LLM_API_KEY=ollama

# L1 导购 Agent 温度参数（覆盖 config.yaml 中的 guide_agent.l1_temperature）
L1_TEMPERATURE=0.3

# ==================== Embedding 配置 ====================

# Embedding API 密钥（!必填! 当前 config.yaml 中硬编码了 siliconflow 密钥）
EMBEDDING_API_KEY=sk-your-key-here

# Embedding 服务地址（默认: https://api.siliconflow.cn/v1）
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1

# ==================== 数据库配置 ====================

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=webcpp
MYSQL_PASSWORD=webcpp123
MYSQL_DATABASE=webcpp

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j123456

# ==================== API 密钥 ====================

# 京东开放平台凭证
JD_APP_KEY=your-jd-app-key
JD_APP_SECRET=your-jd-app-secret
JD_ACCESS_TOKEN=your-jd-access-token

# Cookie 文件输出路径（默认: jd_cookie.json）
JD_COOKIE_OUTPUT=jd_cookie.json
